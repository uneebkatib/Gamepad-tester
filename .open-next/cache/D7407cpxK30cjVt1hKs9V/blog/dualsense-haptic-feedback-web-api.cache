mepadTester Team\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"9\\\",{\\\"name\\\":\\\"robots\\\",\\\"content\\\":\\\"index, follow\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"10\\\",{\\\"name\\\":\\\"googlebot\\\",\\\"content\\\":\\\"index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"11\\\",{\\\"name\\\":\\\"category\\\",\\\"content\\\":\\\"technology\\\"}],[\\\"$\\\",\\\"link\\\",\\\"12\\\",{\\\"rel\\\":\\\"canonical\\\",\\\"href\\\":\\\"https://gamepadtester.live/blog/dualsense-haptic-feedback-web-api\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"13\\\",{\\\"property\\\":\\\"og:title\\\",\\\"content\\\":\\\"Test DualSense Haptics Directly in Your Browser\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"14\\\",{\\\"property\\\":\\\"og:description\\\",\\\"content\\\":\\\"The browser Gamepad API can now trigger real vibration effects on connected controllers. Here is how DualSense haptics work in the browser, what the code looks like, and how to test your actuators for free.\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"15\\\",{\\\"property\\\":\\\"og:url\\\",\\\"content\\\":\\\"https://gamepadtester.live/blog/dualsense-haptic-feedback-web-api\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"16\\\",{\\\"property\\\":\\\"og:image\\\",\\\"content\\\":\\\"http://localhost:3000/dualsense-haptic-test.png\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"17\\\",{\\\"property\\\":\\\"og:image:alt\\\",\\\"content\\\":\\\"Web browser interface showing a DualSense haptic vibration testing tool with motor intensity sliders and waveform visualization\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"18\\\",{\\\"property\\\":\\\"og:type\\\",\\\"content\\\":\\\"article\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"19\\\",{\\\"name\\\":\\\"twitter:card\\\",\\\"content\\\":\\\"summary_large_image\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"20\\\",{\\\"name\\\":\\\"twitter:title\\\",\\\"content\\\":\\\"Professional Gamepad Tester\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"21\\\",{\\\"name\\\":\\\"twitter:description\\\",\\\"content\\\":\\\"Test your gamepad with advanced diagnostics and compatibility checking.\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"22\\\",{\\\"name\\\":\\\"twitter:image\\\",\\\"content\\\":\\\"https://gamepadtester.live/twitter-image.png\\\"}],[\\\"$\\\",\\\"link\\\",\\\"23\\\",{\\\"rel\\\":\\\"icon\\\",\\\"href\\\":\\\"/favicon.svg\\\"}]]\\n\"])</script><script>self.__next_f.push([1,\"4:null\\n\"])</script></body></html>","rsc":"2:I[1344,[\"448\",\"static/chunks/448-b3255ce07fb7af32.js\",\"878\",\"static/chunks/878-2f2af16615291f1f.js\",\"54\",\"static/chunks/54-2c8bd0f3e065c835.js\",\"308\",\"static/chunks/app/blog/%5Bslug%5D/page-f76910757fdfc9d9.js\"],\"default\"]\n3:I[2972,[\"448\",\"static/chunks/448-b3255ce07fb7af32.js\",\"878\",\"static/chunks/878-2f2af16615291f1f.js\",\"54\",\"static/chunks/54-2c8bd0f3e065c835.js\",\"308\",\"static/chunks/app/blog/%5Bslug%5D/page-f76910757fdfc9d9.js\"],\"\"]\n4:I[5878,[\"448\",\"static/chunks/448-b3255ce07fb7af32.js\",\"878\",\"static/chunks/878-2f2af16615291f1f.js\",\"54\",\"static/chunks/54-2c8bd0f3e065c835.js\",\"308\",\"static/chunks/app/blog/%5Bslug%5D/page-f76910757fdfc9d9.js\"],\"Image\"]\n5:I[8349,[\"448\",\"static/chunks/448-b3255ce07fb7af32.js\",\"878\",\"static/chunks/878-2f2af16615291f1f.js\",\"54\",\"static/chunks/54-2c8bd0f3e065c835.js\",\"308\",\"static/chunks/app/blog/%5Bslug%5D/page-f76910757fdfc9d9.js\"],\"default\"]\n6:I[4707,[],\"\"]\n8:I[6423,[],\"\"]\n9:I[8003,[\"185\",\"static/chunks/app/layout-a6e49f9b6a696646.js\"],\"\"]\n7:[\"slug\",\"dualsense-haptic-feedback-web-api\",\"d\"]\n0:[\"D7407cpxK30cjVt1hKs9V\",[[[\"\",{\"children\":[\"blog\",{\"children\":[[\"slug\",\"dualsense-haptic-feedback-web-api\",\"d\"],{\"children\":[\"__PAGE__?{\\\"slug\\\":\\\"dualsense-haptic-feedback-web-api\\\"}\",{}]}]}]},\"$undefined\",\"$undefined\",true],[\"\",{\"children\":[\"blog\",{\"children\":[[\"slug\",\"dualsense-haptic-feedback-web-api\",\"d\"],{\"children\":[\"__PAGE__\",{},[[\"$L1\",[\"$\",\"main\",null,{\"className\":\"min-h-screen bg-background flex flex-col font-sans\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"TechArticle\\\",\\\"headline\\\":\\\"Test DualSense Haptics Directly in Your Browser\\\",\\\"description\\\":\\\"The browser Gamepad API can now trigger real vibration effects on connected controllers. Here is how DualSense haptics work in the browser, what the code looks like, and how to test your actuators for free.\\\",\\\"image\\\":\\\"/dualsense-haptic-test.png\\\",\\\"datePublished\\\":\\\"2026-04-29\\\",\\\"author\\\":{\\\"@type\\\":\\\"Person\\\",\\\"name\\\":\\\"Alex Mercer\\\",\\\"jobTitle\\\":\\\"QA Hardware & Telemetry Engineer\\\",\\\"email\\\":\\\"alex.mercer@gamepadtester.live\\\"},\\\"reviewedBy\\\":{\\\"@type\\\":\\\"Person\\\",\\\"name\\\":\\\"Sarah Chen, PhD\\\",\\\"jobTitle\\\":\\\"Senior Hardware Systems Consultant\\\",\\\"email\\\":\\\"sarah.chen@gamepadtester.live\\\"},\\\"publisher\\\":{\\\"@type\\\":\\\"Organization\\\",\\\"name\\\":\\\"GamepadTester.live\\\"},\\\"mainEntityOfPage\\\":\\\"https://gamepadtester.live/blog/dualsense-haptic-feedback-web-api\\\"}\"}}],[\"$\",\"$L2\",null,{}],[\"$\",\"div\",null,{\"className\":\"container-custom py-8 flex-1\",\"children\":[[\"$\",\"$L3\",null,{\"href\":\"/blog\",\"className\":\"inline-flex items-center gap-1.5 text-xs text-foreground-muted hover:text-primary mb-6 transition\",\"children\":\"← Back to Blog & Repair Guides\"}],[\"$\",\"div\",null,{\"className\":\"grid lg:grid-cols-4 gap-8\",\"children\":[[\"$\",\"div\",null,{\"className\":\"lg:col-span-3\",\"children\":[[\"$\",\"article\",null,{\"className\":\"bg-surface border border-border rounded-2xl shadow-sm overflow-hidden\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative aspect-[2.4/1] w-full\",\"children\":[\"$\",\"$L4\",null,{\"src\":\"/dualsense-haptic-test.png\",\"alt\":\"Web browser interface showing a DualSense haptic vibration testing tool with motor intensity sliders and waveform visualization\",\"fill\":true,\"priority\":true,\"sizes\":\"(max-width: 768px) 100vw, 896px\",\"className\":\"object-cover\"}]}],[\"$\",\"div\",null,{\"className\":\"p-6 sm:p-8\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 text-xs font-semibold text-primary uppercase tracking-wider mb-4\",\"children\":[\"$\",\"span\",null,{\"children\":[\"🎮\",\" \",\"Software API\"]}]}],[\"$\",\"h1\",null,{\"className\":\"text-3xl sm:text-4xl font-black font-display text-foreground mb-5 leading-tight\",\"children\":\"Test DualSense Haptics Directly in Your Browser\"}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-y-2 items-center gap-x-4 border-b border-border/60 pb-5 mb-6 text-xs text-foreground-muted\",\"children\":[[\"$\",\"span\",null,{\"children\":[\"Published: \",[\"$\",\"strong\",null,{\"children\":\"April 30, 2026\"}]]}],[\"$\",\"span\",null,{\"children\":\"•\"}],[\"$\",\"span\",null,{\"children\":\"11 min read\"}],[\"$\",\"span\",null,{\"children\":\"•\"}],[\"$\",\"span\",null,{\"className\":\"flex items-center gap-1 bg-success/15 border border-success/35 text-success px-2.5 py-0.5 rounded-full font-semibold\",\"children\":[\"✓ Reviewed by: \",\"Sarah Chen, PhD\"]}]]}],[\"$\",\"div\",null,{\"className\":\"text-sm text-foreground font-medium leading-relaxed bg-background/50 border-l-4 border-primary p-5 rounded-r-xl mb-8\",\"children\":\"The browser Gamepad API can now trigger real vibration effects on connected controllers. Here is how DualSense haptics work in the browser, what the code looks like, and how to test your actuators for free.\"}],[\"$\",\"div\",null,{\"className\":\"space-y-10 text-foreground-secondary text-sm leading-relaxed\",\"children\":[[\"$\",\"section\",\"0\",{\"className\":\"space-y-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-extrabold text-foreground border-b border-border/40 pb-2\",\"children\":\"The Gamepad API Haptic Model\"}],[[\"$\",\"p\",\"0\",{\"children\":[\"For most of the Web Gamepad API's existence, browsers could only read controller state: buttons, axes, and trigger values. They could not write anything back to the hardware. That changed when the W3C incorporated the GamepadHapticActuator interface into the specification. Browsers that implement this interface can now send vibration commands to connected controllers, enabling web-based games and diagnostic tools to trigger real physical feedback.\"]}],[\"$\",\"p\",\"1\",{\"children\":[\"You access the haptic interface through the gamepad object: navigator.getGamepads() returns the connected gamepads, and each gamepad exposes a hapticActuators array. The primary supported effect type is dual-rumble, which maps to the two independent vibration motors present in modern controllers. On a DualSense, Chrome and Edge additionally route dual-rumble commands through the voice-coil actuators, which produce higher-fidelity output than the simple eccentric rotating mass motors found in older controllers.\"]}]],\"$undefined\"]}],[\"$\",\"section\",\"1\",{\"className\":\"space-y-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-extrabold text-foreground border-b border-border/40 pb-2\",\"children\":\"Dual-Rumble vs Trigger Haptics\"}],[[\"$\",\"p\",\"0\",{\"children\":[\"Standard dual-rumble has two channels: strongMagnitude controls the left heavy motor and produces low-frequency shockwave sensations, while weakMagnitude controls the right light motor and produces high-frequency texture vibrations. Both accept values between 0.0 and 1.0. A short controller click can be simulated by sending a 50ms duration effect with weakMagnitude at 0.8 and strongMagnitude at 0.0. A heavy impact explosion effect would use strongMagnitude at 1.0 with a 200ms duration.\"]}],[\"$\",\"p\",\"1\",{\"children\":[\"DualSense trigger haptics, which are the resistance-feedback adaptive triggers, are a separate subsystem. The Web Gamepad API does not yet support adaptive trigger resistance control in any production browser. Accessing adaptive trigger effects requires either a native PlayStation application, the dualsense-web open-source library over WebHID, or Sony's official PC driver layer. In Chrome, WebHID can be used to send raw feature reports directly to the DualSense firmware, which is how our calibration tool accesses center-reset commands on supported PS5 controllers.\"]}]],[\"$\",\"figure\",null,{\"className\":\"my-4 space-y-2\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative aspect-[2.4/1] w-full rounded-xl overflow-hidden border border-border\",\"children\":[\"$\",\"$L4\",null,{\"src\":\"/dualsense-haptic-test.png\",\"alt\":\"Browser haptic testing interface showing separate left and right motor controls with intensity sliders and trigger resistance settings\",\"fill\":true,\"sizes\":\"(max-width: 768px) 100vw, 672px\",\"className\":\"object-cover\"}]}],[\"$\",\"figcaption\",null,{\"className\":\"text-[10px] text-foreground-muted text-center italic\",\"children\":\"The dual-rumble API exposes strongMagnitude for low-frequency impact and weakMagnitude for high-frequency texture.\"}]]}]]}],[\"$\",\"section\",\"2\",{\"className\":\"space-y-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-extrabold text-foreground border-b border-border/40 pb-2\",\"children\":\"Playing a Vibration Effect: The Code\"}],[[\"$\",\"p\",\"0\",{\"children\":[\"Triggering a rumble effect requires polling the Gamepad API inside a requestAnimationFrame loop, then calling playEffect on the haptic actuator. The method is asynchronous and returns a promise. The effect object accepts four main parameters: duration in milliseconds, startDelay for sequenced effects, strongMagnitude (0.0 to 1.0), and weakMagnitude (0.0 to 1.0). Feature detection is important since browser support is not universal. Always check that hapticActuators exists and contains at least one actuator before calling playEffect. Wrapping the call in try-catch is also advisable since some browsers return rejection on unsupported controller types.\"]}],[\"$\",\"p\",\"1\",{\"children\":[\"One practical pattern worth knowing: calling playEffect cancels any currently running effect before starting the new one. For sustained feedback during held inputs, like trigger pressure in driving games, you need to re-call playEffect on each animation frame with the current intensity value. The startDelay parameter becomes useful when sequencing a series of distinct impacts, like footstep patterns or weapon-fire rhythms in web games. Be aware that the controller must remain connected and the browser tab must be in focus for haptic commands to execute, as background tabs cannot trigger vibration due to browser focus policies.\"]}]],\"$undefined\"]}],[\"$\",\"section\",\"3\",{\"className\":\"space-y-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-extrabold text-foreground border-b border-border/40 pb-2\",\"children\":\"Browser Support and Known Limitations\"}],[[\"$\",\"p\",\"0\",{\"children\":[\"Chrome 68 and Edge 79 both support dual-rumble via GamepadHapticActuator. Firefox has partial implementation that does not work reliably across all controller types. Safari does not support the haptic actuator interface at all as of this writing. On Windows, DualSense haptic commands work best over wired USB. Bluetooth connections on Windows route audio and haptic data through the same channel, and this can create conflicts that cause vibration commands to be silently dropped or delayed.\"]}],[\"$\",\"p\",\"1\",{\"children\":[\"On macOS, the situation is reversed: Bluetooth haptics on DualSense work more consistently because macOS handles the Bluetooth audio and HID channels separately in its driver stack. Linux support varies by kernel version and whether the controller is recognized through the Sony HID driver module. If you are testing and vibration is not responding, always check wired USB first as a baseline before troubleshooting wireless-specific behavior.\"]}]],\"$undefined\"]}],[\"$\",\"section\",\"4\",{\"className\":\"space-y-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-extrabold text-foreground border-b border-border/40 pb-2\",\"children\":\"Testing Your Controller Haptics\"}],[[\"$\",\"p\",\"0\",{\"children\":[\"Our Gamepad Tester includes a vibration preset panel that lets you trigger test effects across the full power range, from a subtle 5% weak motor pulse that verifies your light actuator is functioning to 100% strong motor capacity that confirms your heavy motor has full mechanical travel. If one motor does not respond at all, its actuator coil may be disconnected or the motor assembly may need physical inspection. If you hear a grinding sound during vibration, debris inside the motor housing is common and can often be cleared by placing the controller face-down and running the motor at full capacity for 3 to 5 seconds.\"]}],[\"$\",\"p\",\"1\",{\"children\":[\"You can also use the Gamepad Tester vibration panel to verify that your browser is correctly routing haptic commands to the right controller when multiple gamepads are connected. The panel labels each actuator by controller index and reports whether the playEffect call returned successfully or threw an error. For developers building haptic experiences, this is a useful way to confirm that your playEffect implementation is reaching the hardware before integrating it into a game loop. Connect your controller, navigate to our calibration tool, and use the Haptic Test section alongside the stick circularity and drift detection panels.\"]}]],\"$undefined\"]}],[\"$\",\"section\",\"5\",{\"className\":\"space-y-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-extrabold text-foreground border-b border-border/40 pb-2\",\"children\":\"Implementing Fallback Strategies for Safari and Firefox\"}],[[\"$\",\"p\",\"0\",{\"children\":[\"Because haptic support is not universal across all browsers, developers should implement defensive coding patterns. Safari does not expose the GamepadHapticActuator interface, which will cause references to fail.\"]}],[\"$\",\"p\",\"1\",{\"children\":[\"To prevent runtime errors, query the presence of hapticActuators before calling playEffect. If haptics are unsupported, provide visual feedback in the UI or use the device audio output to simulate rumble textures.\"]}]],\"$undefined\"]}],[\"$\",\"section\",\"6\",{\"className\":\"space-y-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-extrabold text-foreground border-b border-border/40 pb-2\",\"children\":\"Optimizing Performance with Animation Frame Loops\"}],[[\"$\",\"p\",\"0\",{\"children\":[\"Sending redundant playEffect calls to the controller can saturate the USB bus, leading to input signal delays or temporary controller freezes. Ensure you debounce haptic updates to avoid queue congestion.\"]}],[\"$\",\"p\",\"1\",{\"children\":[\"Store the previous haptic intensity state and only call playEffect when values deviate by more than a 0.05 threshold. This keeps the polling rate clean and preserves resources for standard game logic.\"]}]],\"$undefined\"]}],[\"$\",\"section\",\"7\",{\"className\":\"space-y-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-extrabold text-foreground border-b border-border/40 pb-2\",\"children\":\"Future Specifications: Multi-Channel Voice-Coil API\"}],[[\"$\",\"p\",\"0\",{\"children\":[\"The W3C is currently drafting proposals to support direct audio-to-haptics streaming for modern gamepads. This will allow web games to route multi-channel high-definition audio files straight to the voice-coil actuators.\"]}],[\"$\",\"p\",\"1\",{\"children\":[\"This update will bridge the gap between native PlayStation haptics and browser applications, enabling immersive and highly detailed texture rendering on PC web browsers.\"]}]],\"$undefined\"]}]]}],[\"$\",\"div\",null,{\"className\":\"mt-10 p-5 bg-primary/5 border border-primary/20 rounded-xl flex flex-col sm:flex-row gap-4 items-start sm:items-center\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex-1 space-y-1\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-xs font-bold text-primary block\",\"children\":\"Free Tool\"}],[\"$\",\"p\",null,{\"className\":\"text-xs text-foreground-muted leading-relaxed\",\"children\":\"Use our free Gamepad Tester to verify stick drift, check axis coordinates, run circularity tests, and calibrate deadzones — no download required.\"}]]}],[\"$\",\"div\",null,{\"className\":\"flex gap-2 shrink-0\",\"children\":[[\"$\",\"$L3\",null,{\"href\":\"/\",\"className\":\"px-4 py-2 bg-primary text-white rounded-lg text-xs font-bold hover:bg-primary-hover transition\",\"children\":\"Test Your Controller\"}],[\"$\",\"$L3\",null,{\"href\":\"/calibration\",\"className\":\"px-4 py-2 bg-background border border-border text-foreground text-xs font-bold rounded-lg hover:bg-surface transition\",\"children\":\"Calibration Tool\"}]]}]]}],[\"$\",\"div\",null,{\"className\":\"mt-8 pt-6 border-t border-border/60 flex flex-wrap gap-2\",\"children\":[[\"$\",\"span\",\"Gamepad API\",{\"className\":\"bg-background border border-border/80 px-2 py-0.5 rounded text-xs text-foreground-muted\",\"children\":[\"#\",\"Gamepad API\"]}],[\"$\",\"span\",\"WebDev\",{\"className\":\"bg-background border border-border/80 px-2 py-0.5 rounded text-xs text-foreground-muted\",\"children\":[\"#\",\"WebDev\"]}],[\"$\",\"span\",\"Haptics\",{\"className\":\"bg-background border border-border/80 px-2 py-0.5 rounded text-xs text-foreground-muted\",\"children\":[\"#\",\"Haptics\"]}],[\"$\",\"span\",\"PlayStation 5\",{\"className\":\"bg-background border border-border/80 px-2 py-0.5 rounded text-xs text-foreground-muted\",\"children\":[\"#\",\"PlayStation 5\"]}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"bg-surface/50 border border-border/50 rounded-xl p-4 mt-6 text-xs text-foreground-muted leading-relaxed\",\"children\":[[\"$\",\"strong\",null,{\"className\":\"text-foreground block mb-1\",\"children\":\"Hardware Modification Disclaimer:\"}],\"DIY diagnostic checkups and repairs carry safety risks. Ensure all power supplies are unplugged and follow safety procedures. GamepadTester.live is not liable for components damaged during disassembly or repair attempts.\"]}]]}],[\"$\",\"div\",null,{\"className\":\"lg:col-span-1 space-y-6\",\"children\":[[\"$\",\"div\",null,{\"className\":\"bg-surface border border-border rounded-xl p-5 shadow-sm\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-[10px] font-bold font-display text-primary uppercase tracking-widest block mb-3\",\"children\":\"Written By\"}],[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"img\",null,{\"src\":\"/alex-mercer.jpg\",\"alt\":\"Alex Mercer portrait\",\"className\":\"w-10 h-10 rounded-full object-cover border border-border\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"$L3\",null,{\"href\":\"/author/alex-mercer\",\"className\":\"text-xs font-bold text-foreground hover:text-primary transition leading-tight block\",\"children\":\"Alex Mercer\"}],[\"$\",\"span\",null,{\"className\":\"text-[9px] text-foreground-muted\",\"children\":\"QA Hardware & Telemetry Engineer\"}]]}]]}],[\"$\",\"p\",null,{\"className\":\"text-[10px] text-foreground-secondary leading-relaxed mb-3\",\"children\":\"Alex maintains the Web Gamepad API vendor ID mapping database. He benchmarks input lag and stick drift tolerances across over 50+ gamepad models annually. He is passionate about console preservation and hardware firmware modifications.\"}],[\"$\",\"div\",null,{\"className\":\"space-y-1.5 border-t border-border/60 pt-3\",\"children\":[[[\"$\",\"span\",\"QA Lead Certified\",{\"className\":\"block text-[8px] text-foreground-muted\",\"children\":[\"🏅 \",\"QA Lead Certified\"]}]],[\"$\",\"a\",null,{\"href\":\"mailto:alex.mercer@gamepadtester.live\",\"className\":\"block text-[9px] text-acce