l,{\"className\":\"text-[10px] text-foreground-secondary leading-relaxed mb-3\",\"children\":\"Sarah is an electrical engineer and input device specialist. She consults on signal latency testing, firmware analysis, and cross-platform Gamepad API calibration protocols. Her academic research focuses on micro-contact potentiometer noise signals and mitigation patterns.\"}],[\"$\",\"div\",null,{\"className\":\"space-y-1.5 border-t border-border/60 pt-3\",\"children\":[[[\"$\",\"span\",\"Ph.D. in Electrical Engineering\",{\"className\":\"block text-[8px] text-foreground-muted\",\"children\":[\"🏅 \",\"Ph.D. in Electrical Engineering\"]}]],[\"$\",\"a\",null,{\"href\":\"mailto:sarah.chen@gamepadtester.live\",\"className\":\"block text-[9px] text-accent hover:underline mt-1\",\"children\":[\"✉️ \",\"sarah.chen@gamepadtester.live\"]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"bg-surface border border-border rounded-xl p-5 shadow-sm\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xs font-bold font-display text-foreground uppercase tracking-wider mb-3\",\"children\":\"Recommended\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"div\",\"1\",{\"className\":\"border-b border-border/60 pb-3 last:border-b-0 last:pb-0\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-[9px] text-foreground-muted block mb-1\",\"children\":\"Hardware Mods\"}],[\"$\",\"$L3\",null,{\"href\":\"/blog/hall-effect-joystick-swaps\",\"className\":\"text-xs font-bold font-display text-foreground hover:text-primary leading-tight transition block\",\"children\":\"Hall Effect Joystick Upgrade: End Stick Drift Forever\"}]]}],[\"$\",\"div\",\"2\",{\"className\":\"border-b border-border/60 pb-3 last:border-b-0 last:pb-0\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-[9px] text-foreground-muted block mb-1\",\"children\":\"DIY Repair\"}],[\"$\",\"$L3\",null,{\"href\":\"/blog/cleaning-potentiometer-carbon-tracks\",\"className\":\"text-xs font-bold font-display tex