</script><script src=\"/_next/static/chunks/54-2c8bd0f3e065c835.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/blog/%5Bslug%5D/page-f76910757fdfc9d9.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/layout-a6e49f9b6a696646.js\" async=\"\"></script><link rel=\"preload\" href=\"https://www.googletagmanager.com/gtag/js?id=G-YDQJ9NW3VG\" as=\"script\"/><link rel=\"alternate\" hrefLang=\"en\" href=\"https://gamepadtester.live\"/><meta name=\"color-scheme\" content=\"light dark\"/><title>How to Use a PS5 DualSense Controller on PC: Complete Guide</title><meta name=\"description\" content=\"Want to use your PS5 DualSense controller on PC? Learn how to connect via Bluetooth or USB, configure Steam Input, use DS4Windows, and enable adaptive triggers.\"/><meta name=\"author\" content=\"GamepadTester Team\"/><link rel=\"manifest\" href=\"/manifest.json\" crossorigin=\"use-credentials\"/><meta name=\"keywords\" content=\"PlayStation 5,Compatibility,Steam,DS4Windows,Windows 11\"/><meta name=\"creator\" content=\"GamepadTester Team\"/><meta name=\"robots\" content=\"index, follow\"/><meta name=\"googlebot\" content=\"index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1\"/><meta name=\"category\" content=\"technology\"/><link rel=\"canonical\" href=\"https://gamepadtester.live/blog/ps5-controller-on-pc\"/><meta property=\"og:title\" content=\"How to Use a PS5 DualSense Controller on PC: Complete Guide\"/><meta property=\"og:description\" content=\"Want to use your PS5 DualSense controller on PC? Learn how to connect via Bluetooth or USB, configure Steam Input, use DS4Windows, and enable adaptive triggers.\"/><meta property=\"og:url\" content=\"https://gamepadtester.live/blog/ps5-controller-on-pc\"/><meta property=\"og:image\" content=\"http://localhost:3000/dualsense-haptic-test.png\"/><meta property=\"og:image:alt\" content=\"Sony PlayStation 5 DualSense controller next to a gaming PC\"/><meta property=\"og:type\" content=\"article\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Professional Gamepad Tester\"/><meta name=\"twitter:description\" content=\"Test your gamepad with advanced diagnostics and compatibility checking.\"/><meta name=\"twitter:image\" content=\"https://gamepadtester.live/twitter-image.png\"/><link rel=\"icon\" href=\"/favicon.svg\"/><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"WebApplication\",\"name\":\"GamepadTester.live\",\"description\":\"Professional gamepad and controller testing platform with diagnostics\",\"url\":\"https://gamepadtester.live\",\"applicationCategory\":\"UtilityApplication\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"USD\"}}</script><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body><main class=\"min-h-screen bg-background flex flex-col font-sans\"><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"TechArticle\",\"headline\":\"How to Use a PS5 DualSense Controller on PC: Complete Guide\",\"description\":\"Want to use your PS5 DualSense controller on PC? Learn how to connect via Bluetooth or USB, configure Steam Input, use DS4Windows, and enable adaptive triggers.\",\"image\":\"/dualsense-haptic-test.png\",\"datePublished\":\"2026-06-05\",\"author\":{\"@type\":\"Person\",\"name\":\"Alex Mercer\",\"jobTitle\":\"QA Hardware & Telemetry Engineer\",\"email\":\"alex.mercer@gamepadtester.live\"},\"reviewedBy\":{\"@type\":\"Person\",\"name\":\"Marcus Vance\",\"jobTitle\":\"Lead Controller Repair Technician\",\"email\":\"marcus.vance@gamepadtester.live\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"GamepadTester.live\"},\"mainEntityOfPage\":\"https://gamepadtester.live/blog/ps5-controller-on-pc\"}</script><nav class=\"sticky top-0 z-50 transition-all duration-300 bg-background/80 backdrop-blur border-b border-border/50\"><div class=\"container-custom\"><div class=\"flex justify-between items-center h-16\"><a class=\"flex items-center gap-2 text-xl font-bold text-primary hover:opacity-80 transition-opacity\" href=\"/\"><svg class=\"inline-block\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#ff7a00\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"display:inline-block;vertical-align:middle\"><rect x=\"2\" y=\"6\" width=\"20\" height=\"12\" rx=\"4\" fill=\"rgba(255, 122, 0, 0.12)\"></rect><path d=\"M6 12h4M8 10v4\" stroke=\"#ff7a00\" stroke-width=\"2.2\"></path><circle cx=\"16\" cy=\"10\" r=\"1\" fill=\"#ff7a00\" stroke=\"none\"></circle><circle cx=\"18\" cy=\"12\" r=\"1\" fill=\"#ff7a00\" stroke=\"none\"></circle><circle cx=\"16\" cy=\"14\" r=\"1\" fill=\"#ff7a00\" stroke=\"none\"></circle><circle cx=\"14\" cy=\"12\" r=\"1\" fill=\"#ff7a00\" stroke=\"none\"></circle><line x1=\"11\" y1=\"11\" x2=\"11.5\" y2=\"11.5\" stroke=\"#ff7a00\" stroke-width=\"1.5\"></line><line x1=\"13\" y1=\"11\" x2=\"12.5\" y2=\"11.5\" stroke=\"#ff7a00\" stroke-width=\"1.5\"></line></svg><span>GamepadTester</span></a><div class=\"hidden md:flex items-center gap-1\"><a class=\"px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200 text-foreground-secondary hover:text-foreground hover:bg-surface-hover\" href=\"/\">Home</a><a class=\"px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200 text-foreground-secondary hover:text-foreground hover:bg-surface-hover\" href=\"/calibration\">Calibration</a><a class=\"px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200 text-foreground-secondary hover:text-foreground hover:bg-surface-hover\" href=\"/troubleshooting\">Help</a><a class=\"px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200 text-foreground-secondary hover:text-foreground hover:bg-surface-hover\" href=\"/blog\">Blog</a><a class=\"px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200 text-foreground-secondary hover:text-foreground hover:bg-surface-hover\" href=\"/about\">About</a><button class=\"ml-3 p-2 rounded-lg bg-surface hover:bg-surface-hover border border-border transition-all duration-200\" aria-label=\"Toggle theme\" title=\"Switch to dark mode\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z\"></path></svg></button></div><div class=\"md:hidden flex items-center gap-2\"><button class=\"p-2 rounded-lg bg-surface border border-border\" aria-label=\"Toggle theme\">🌙</button><button class=\"p-2 rounded-lg bg-surface border border-border\" aria-label=\"Menu\"><svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 6h16M4 12h16M4 18h16\"></path></svg></button></div></div></div></nav><div class=\"container-custom py-8 flex-1\"><a class=\"inline-flex items-center gap-1.5 text-xs text-foreground-muted hover:text-primary mb-6 transition\" href=\"/blog\">← Back to Blog &amp; Repair Guides</a><div class=\"grid lg:grid-cols-4 gap-8\"><div class=\"lg:col-span-3\"><article class=\"bg-surface border border-border rounded-2xl shadow-sm overflow-hidden\"><div class=\"relative aspect-[2.4/1] w-full\"><img alt=\"Sony PlayStation 5 DualSense controller next to a gaming PC\" fetchPriority=\"high\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"(max-width: 768px) 100vw, 896px\" srcSet=\"/_next/image?url=%2Fdualsense-haptic-test.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fdualsense-haptic-test.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fdualsense-haptic-test.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fdualsense-haptic-test.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fdualsense-haptic-test.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fdualsense-haptic-test.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fdualsense-haptic-test.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fdualsense-haptic-test.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fdualsense-haptic-test.png&amp;w=3840&amp;q=75\"/></div><div class=\"p-6 sm:p-8\"><div class=\"flex items-center gap-2 text-xs font-semibold text-primary uppercase tracking-wider mb-4\"><span>🎮<!-- --> <!-- -->Compatibility</span></div><h1 class=\"text-3xl sm:text-4xl font-black font-display text-foreground mb-5 leading-tight\">How to Use a PS5 DualSense Controller on PC: Complete Guide</h1><div class=\"flex flex-wrap gap-y-2 items-center gap-x-4 border-b border-border/60 pb-5 mb-6 text-xs text-foreground-muted\"><span>Published: <strong>June 6, 2026</strong></span><span>•</span><span>10 min read</span><span>•</span><span class=\"flex items-center gap-1 bg-success/15 border border-success/35 text-success px-2.5 py-0.5 rounded-full font-semibold\">✓ Reviewed by: <!-- -->Marcus Vance</span></div><div class=\"text-sm text-foreground font-medium leading-relaxed bg-background/50 border-l-4 border-primary p-5 rounded-r-xl mb-8\">Want to use your PS5 DualSense controller on PC? Learn how to connect via Bluetooth or USB, configure Steam Input, use DS4Windows, and enable adaptive triggers.</div><div class=\"space-y-10 text-foreground-secondary text-sm leading-relaxed\"><section class=\"space-y-4\"><h2 class=\"text-lg font-extrabold text-foreground border-b border-border/40 pb-2\">Introduction: The DualSense PC Experience</h2><p>Sony&#x27;s DualSense controller is one of the most advanced gamepads available, offering detailed haptic feedback and tension-based adaptive triggers. While originally designed for the PlayStation 5, the DualSense is fully compatible with Windows 10 and Windows 11. More PC games are adding native support for its unique hardware features every month.</p><p>Depending on whether you connect the controller via USB or Bluetooth, your operating system will handle the inputs differently. Wired connections provide the maximum bandwidth required for advanced audio and haptics, while Bluetooth offers convenient wireless play.</p></section><section class=\"space-y-4\"><h2 class=\"text-lg font-extrabold text-foreground border-b border-border/40 pb-2\">Connecting the DualSense to PC: USB and Bluetooth</h2><p>To connect via USB, plug a high-quality USB-C to USB-A or USB-C to USB-C cable into your controller and a motherboard port on your PC. Windows will immediately recognize the device as a DualSense Wireless Controller and configure standard audio and input profiles.</p><p>To connect wirelessly via Bluetooth, press and hold the central PlayStation button and the Share button (top-left) simultaneously until the light bar under the touchpad begins flashing rapidly in a double-blink pattern. Open Windows Settings, go to Bluetooth &amp; Devices, select Add Device, choose Bluetooth, and select Wireless Controller. If the controller drops connection unexpectedly, consult our <a class=\"text-primary hover:underline font-semibold\" href=\"/blog/controller-not-connecting-pc\">guide on fixing controllers not connecting to PC</a>.</p></section><section class=\"space-y-4\"><h2 class=\"text-lg font-extrabold text-foreground border-b border-border/40 pb-2\">Configuring Steam Input for DualSense Support</h2><p>Valve&#x27;s Steam platform offers the most robust support for PlayStation controllers on PC. To activate it, open Steam, click Steam in the top-left menu, choose Settings, and navigate to the Controller tab. Toggle the switch to enable PlayStation Controller Support.</p><p>Steam Input automatically translates PlayStation HID signals into XInput, allowing the DualSense to work seamlessly with any game in your Steam library. You can customize the touchpad buttons, configure gyro aiming, and change the light bar colors through the Steam layout configurator. For general Steam setup, check our <a class=\"text-primary hover:underline font-semibold\" href=\"/blog/controller-on-steam\">guide on using any controller on Steam</a>.</p></section><section class=\"space-y-4\"><h2 class=\"text-lg font-extrabold text-foreground border-b border-border/40 pb-2\">Using DS4Windows for Non-Steam Games</h2><p>For games purchased outside of Steam (such as on the Epic Games Store, GOG, or Xbox App), you can use the free open-source software DS4Windows. This utility emulates an Xbox 360 controller or a DualShock 4 controller, translating DualSense inputs at the system driver level.</p><p>Download DS4Windows and the required ViGEmBus driver. Connect your controller, open the software, and create a default profile. Ensure you enable the Hide DS4 Controller setting in DS4Windows settings to prevent games from registering duplicate inputs. If your browser fails to detect the controller with DS4Windows active, check our <a class=\"text-primary hover:underline font-semibold\" href=\"/blog/gamepad-not-detected-browser\">troubleshooting steps for gamepads not detected in browser</a>.</p></section><section class=\"space-y-4\"><h2 class=\"text-lg font-extrabold text-foreground border-b border-border/40 pb-2\">Enabling Adaptive Triggers and Haptic Feedback on PC</h2><p>To experience advanced haptic feedback and adaptive triggers, you must connect the DualSense controller via a wired USB connection. Bluetooth bandwidth on Windows is not wide enough to carry the multi-channel haptic audio signals and input commands simultaneously.</p><p>The game you are playing must also have native support for these features. Titles like Cyberpunk 2077, Returnal, Spider-Man Remastered, and Metro Exodus automatically activate haptic motors and trigger tension when a wired DualSense is detected. For web developers looking to build haptic experiences in browser games, check our <a class=\"text-primary hover:underline font-semibold\" href=\"/blog/dualsense-haptic-feedback-web-api\">guide on the DualSense haptics web API</a>.</p><figure class=\"my-4 space-y-2\"><div class=\"relative aspect-[2.4/1] w-full rounded-xl overflow-hidden border border-border\"><img alt=\"DualSense haptic actuator testing interface parameters\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"(max-width: 768px) 100vw, 672px\" srcSet=\"/_next/image?url=%2Fdualsense-haptic-test.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fdualsense-haptic-test.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fdualsense-haptic-test.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fdualsense-haptic-test.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fdualsense-haptic-test.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fdualsense-haptic-test.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fdualsense-haptic-test.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fdualsense-haptic-test.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fdualsense-haptic-test.png&amp;w=3840&amp;q=75\"/></div><figcaption class=\"text-[10px] text-foreground-muted text-center italic\">Wired USB connection is required for multi-channel haptic audio feedback</figcaption></figure></section><section class=\"space-y-4\"><h2 class=\"text-lg font-extrabold text-foreground border-b border-border/40 pb-2\">Verifying Inputs on Gamepad Tester</h2><p>After setting up your connection, it is a good idea to verify that every button, trigger, and axis is transmitting signals correctly. Open our gamepad tester homepage, press any button on your DualSense to wake the Gamepad API, and monitor the live coordinate displays.</p><p>You can also run a quick circularity check on the sticks to verify there is no drift. If you want a specialized diagnostic check for PlayStation controllers, visit our <a class=\"text-primary hover:underline font-semibold\" href=\"/blog/test-analog-stick-drift-online\">dedicated guide to testing a PS5 controller online</a>.</p></section><section class=\"space-y-4\"><h2 class=\"text-lg font-extrabold text-foreground border-b border-border/40 pb-2\">Advanced DS4Windows Profile Customization</h2><p>With DS4Windows active, you can customize the DualSense touchpad and gyro sensors. You can map touchpad swipe gestures to control your Windows mouse cursor, or bind specific hotkeys to different zones.</p><p>This is particularly helpful for navigating desktop launchers without reaching for your physical mouse. Adjust the gyro-to-mouse sensitivity in the settings to enable precise motion-controlled aiming in FPS titles.</p></section><section class=\"space-y-4\"><h2 class=\"text-lg font-extrabold text-foreground border-b border-border/40 pb-2\">Troubleshooting PlayStation Controller Audio Jack Conflict</h2><p>When connected via USB, Windows recognizes the DualSense built-in audio card and often overrides your primary speakers, diverting all system sound to the controller headphone jack.</p><p>To restore sound to your speakers, right-click the speaker icon in the Windows taskbar, select Sound Settings, and change your output device back to your computer main speakers.</p></section></div><div class=\"mt-10 p-5 bg-primary/5 border border-primary/20 rounded-xl flex flex-col sm:flex-row gap-4 items-start sm:items-center\"><div class=\"flex-1 space-y-1\"><span class=\"text-xs font-bold text-primary block\">Free Tool</span><p class=\"text-xs text-foreground-muted leading-relaxed\">Use our free Gamepad Tester to verify stick drift, check axis coordinates, run circularity tests, and calibrate deadzones — no download required.</p></div><div class=\"flex gap-2 shrink-0\"><a class=\"px-4 py-2 bg-primary text-white rounded-lg text-xs font-bold hover:bg-primary-hover transition\" href=\"/\">Test Your Controller</a><a class=\"px-4 py-2 bg-background border border-border text-foreground text-xs font-bold rounded-lg hover:bg-surface transition\" href=\"/calibration\">Calibration Tool</a></div></div><div class=\"mt-8 pt-6 border-t border-border/60 flex flex-wrap gap-2\"><span class=\"bg-background border border-border/80 px-2 py-0.5 rounded text-xs text-foreground-muted\">#<!-- -->PlayStation 5</span><span class=\"bg-background border border-border/80 px-2 py-0.5 rounded text-xs text-foreground-muted\">#<!-- -->Compatibility</span><span class=\"bg-background border border-border/80 px-2 py-0.5 rounded text-xs text-foreground-muted\">#<!-- -->Steam</span><span class=\"bg-background border border-border/80 px-2 py-0.5 rounded text-xs text-foreground-muted\">#<!-- -->DS4Windows</span><span class=\"bg-background border border-border/80 px-2 py-0.5 rounded text-xs text-foreground-muted\">#<!-- -->Windows 11</span></div></div></article><div class=\"bg-surface/50 border border-border/50 rounded-xl p-4 mt-6 text-xs text-foreground-muted leading-relaxed\"><strong class=\"text-foreground block mb-1\">Hardware Modification Disclaimer:</strong>DIY diagnostic checkups and repairs carry safety risks. Ensure all power supplies are unplugged and follow safety procedures. GamepadTester.live is not liable for components damaged during disassembly or repair attempts.</div></div><div class=\"lg:col-span-1 space-y-6\"><div class=\"bg-surface border border-border rounded-xl p-5 shadow-sm\"><span class=\"text-[10px] font-bold font-display text-primary uppercase tracking-widest block mb-3\">Written By</span><div class=\"flex items-center gap-2 mb-3\"><img src=\"/alex-mercer.jpg\" alt=\"Alex Mercer portrait\" class=\"w-10 h-10 rounded-full object-cover border border-border\"/><div><a class=\"text-xs font-bold text-foreground hover:text-primary transition leading-tight block\" href=\"/author/alex-mercer\">Alex Mercer</a><span class=\"text-[9px] text-foreground-muted\">QA Hardware &amp; Telemetry Engineer</span></div></div><p class=\"text-[10px] text-foreground-secondary leading-relaxed mb-3\">Alex maintains the Web Gamepad API vendor ID mapping database. He benchmarks input lag and stick drift tolerances across over 50+ gamepad models annually. He is passionate about console preservation and hardware firmware modifications.</p><div class=\"space-y-1.5 border-t border-border/60 pt-3\"><span class=\"block text-[8px] text-foreground-muted\">🏅 <!-- -->QA Lead Certified</span><a href=\"mailto:alex.mercer@gamepadtester.live\" class=\"block text-[9px] text-accent hover:underline mt-1\">✉️ <!-- -->alex.mercer@gamepadtester.live</a></div></div><div class=\"bg-surface border border-border rounded-xl p-5 shadow-sm\"><span class=\"text-[10px] font-bold font-display text-success uppercase tracking-widest block mb-3\">Technical Reviewer</span><div class=\"flex items-center gap-2 mb-3\"><img src=\"/marcus-vance.jpg\" alt=\"Marcus Vance portrait\" class=\"w-10 h-10 rounded-full object-cover border border-border\"/><div><a class=\"text-xs font-bold text-foreground hover:text-primary transition leading-tight block\" href=\"/author/marcus-vance\">Marcus Vance</a><span class=\"text-[9px] text-foreground-muted\">Lead Controller Repair Technician</span></div></div><p class=\"text-[10px] text-foreground-secondary leading-relaxed mb-3\">Marcus has 12+ years of experience repairing and modding console controllers. He specializes in mechanical joystick replacements, carbon track restoration, and Hall-effect sensor upgrades. He runs a diagnostic workshop and frequently advises input device manufacturers on switch wear resistance.</p><div class=\"space-y-1.5 border-t border-border/60 pt-3\"><span class=\"block text-[8px] text-foreground-muted\">🏅 <!-- -->IPC-A-610 Soldering Certified</span><a href=\"mailto:marcus.vance@gamepadtester.live\" class=\"block text-[9px] text-accent hover:underline mt-1\">✉️ <!-- -->marcus.vance@gamepadtester.live</a></div></div><div class=\"bg-surface border border-border rounded-xl p-5 shadow-sm\"><h3 class=\"text-xs font-bold font-display text-foreground uppercase tracking-wider mb-3\">Recommended</h3><div class=\"space-y-4\"><div class=\"border-b border-border/60 pb-3 last:border-b-0 last:pb-0\"><span class=\"text-[9px] text-foreground-muted block mb-1\">Hardware Mods</span><a class=\"text-xs font-bold font-display text-foreground hover:text-primary leading-tight transition block\" href=\"/blog/hall-effect-joystick-swaps\">Hall Effect Joystick Upgrade: End Stick Drift Forever</a></div><div class=\"border-b border-border/60 pb-3 last:border-b-0 last:pb-0\"><span class=\"text-[9px] text-foreground-muted block mb-1\">DIY Repair</span><a class=\"text-xs font-bold font-display text-foreground hover:text-primary leading-tight transition block\" href=\"/blog/cleaning-potentiometer-carbon-tracks\">Clean Controller Carbon Tracks and Kill the Drift</a></div></div></div><div class=\"bg-surface border border-border rounded-xl p-5 shadow-sm space-y-3\"><h3 class=\"text-xs font-bold font-display text-foreground uppercase tracking-wider\">Free Tools</h3><a class=\"block text-xs text-foreground-muted hover:text-primary transition py-1.5 border-b border-border/40 last:border-0\" href=\"/\">🎮 Gamepad Tester</a><a class=\"block text-xs text-foreground-muted hover:text-primary transition py-1.5 border-b border-border/40 last:border-0\" href=\"/calibration\">🎯 Calibration Tool</a><a class=\"block text-xs text-foreground-muted hover:text-primary transition py-1.5\" href=\"/troubleshooting\">🔧 Troubleshooting Guide</a></div></div></div></div><footer class=\"bg-surface border-t border-border py-12\"><div class=\"container-custom\"><div class=\"grid md:grid-cols-3 gap-8 mb-8\"><div><h3 class=\"text-xl font-bold gradient-text mb-4 flex items-center gap-2\"><svg class=\"inline-block\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#ff7a00\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"display:inline-block;vertical-align:middle\"><rect x=\"2\" y=\"6\" width=\"20\" height=\"12\" rx=\"4\" fill=\"rgba(255, 122, 0, 0.12)\"></rect><path d=\"M6 12h4M8 10v4\" stroke=\"#ff7a00\" stroke-width=\"2.2\"></path><circle cx=\"16\" cy=\"10\" r=\"1\" fill=\"#ff7a00\" stroke=\"none\"></circle><circle cx=\"18\" cy=\"12\" r=\"1\" fill=\"#ff7a00\" stroke=\"none\"></circle><circle cx=\"16\" cy=\"14\" r=\"1\" fill=\"#ff7a00\" stroke=\"none\"></circle><circle cx=\"14\" cy=\"12\" r=\"1\" fill=\"#ff7a00\" stroke=\"none\"></circle><line x1=\"11\" y1=\"11\" x2=\"11.5\" y2=\"11.5\" stroke=\"#ff7a00\" stroke-width=\"1.5\"></line><line x1=\"13\" y1=\"11\" x2=\"12.5\" y2=\"11.5\" stroke=\"#ff7a00\" stroke-width=\"1.5\"></line></svg> GamepadTester</h3><p class=\"text-foreground-muted text-sm\">Professional gamepad testing platform with advanced diagnostics.</p></div><div><h4 class=\"font-semibold mb-4\">Quick Links</h4><ul class=\"space-y-2 text-sm text-foreground-muted\"><li><a class=\"hover:text-accent transition\" href=\"/\">Home</a></li><li><a class=\"hover:text-accent transition\" href=\"/calibration\">Calibration</a></li><li><a class=\"hover:text-accent transition\" href=\"/blog\">Blog &amp; Guides</a></li></ul></div><div><h4 class=\"font-semibold mb-4\">Resources</h4><ul class=\"space-y-2 text-sm text-foreground-muted\"><li><a class=\"hover:text-accent transition\" href=\"/troubleshooting\">Troubleshooting</a></li><li><a class=\"hover:text-accent transition\" href=\"/about\">About Us</a></li><li><a class=\"hover:text-accent transition\" href=\"/privacy\">Privacy Policy</a></li><li><a class=\"hover:text-accent transition\" href=\"/terms\">Terms of Use</a></li><li><a class=\"hover:text-accent transition\" href=\"/contact\">Contact Us</a></li></ul></div></div><div class=\"border-t border-border pt-8 flex justify-between items-center text-sm text-foreground-muted\"><p>© <!-- -->2026<!-- --> GamepadTester.live. All rights reserved.</p><div class=\"flex gap-4\"><a class=\"hover:text-accent transition\" href=\"/privacy\">Privacy</a><a class=\"hover:text-accent transition\" href=\"/terms\">Terms</a></div></div></div></footer></ma